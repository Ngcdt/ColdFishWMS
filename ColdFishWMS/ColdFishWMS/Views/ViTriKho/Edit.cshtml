@model ColdFishWMS.Models.Entities.ViTriKho
@{
    ViewData["Title"] = "Cập nhật Vị trí kho";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
             <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a asp-controller="ViTriKho" asp-action="Index" class="text-decoration-none">Quản lý vị trí kho</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Cập nhật</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Cập nhật Vị trí</h2>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="MaViTri" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MaViTri" class="form-label fw-bold">Mã vị trí <span class="text-danger">*</span></label>
                        <input asp-for="MaViTri" class="form-control" />
                        <span asp-validation-for="MaViTri" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="TenViTri" class="form-label fw-bold">Tên mô tả</label>
                        <input asp-for="TenViTri" class="form-control" />
                        <span asp-validation-for="TenViTri" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Khu" class="form-label">Khu vực</label>
                        <input asp-for="Khu" class="form-control" />
                        <span asp-validation-for="Khu" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Ke" class="form-label">Kệ chứa</label>
                        <input asp-for="Ke" class="form-control" />
                        <span asp-validation-for="Ke" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Tang" class="form-label">Tầng</label>
                        <input asp-for="Tang" class="form-control" />
                        <span asp-validation-for="Tang" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input class="form-check-input" type="checkbox" asp-for="TrangThaiTrong">
                    <label class="form-check-label" asp-for="TrangThaiTrong">
                        Trạng thái Trống
                    </label>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model ColdFishWMS.Models.Entities.NguoiDung
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="container-fluid">
     <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Quản lý Người dùng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="fw-bold mb-0 text-primary"><i class="fas fa-id-card me-2"></i> Thông tin chi tiết: @Model.HoTen</h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <!-- Cột 1: Thông tin tài khoản -->
                <div class="col-md-6 border-end">
                    <h6 class="text-secondary mb-3 text-uppercase small fw-bold">Thông tin tài khoản</h6>
                    <dl class="row">
                        <dt class="col-sm-4 text-muted">ID người dùng</dt>
                        <dd class="col-sm-8 fw-bold">No. @Model.MaNguoiDung</dd>

                        <dt class="col-sm-4 text-muted">Tên đăng nhập</dt>
                        <dd class="col-sm-8">@Model.TenDangNhap</dd>

                        <dt class="col-sm-4 text-muted">Vai trò</dt>
                        <dd class="col-sm-8"><span class="badge bg-primary">@Model.VaiTro?.TenVaiTro</span></dd>

                        <dt class="col-sm-4 text-muted">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @if (Model.TrangThaiHoatDong)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger">Đã khóa</span>
                            }
                        </dd>


                    </dl>
                </div>

                <!-- Cột 2: Thông tin cá nhân -->
                <div class="col-md-6 ps-md-4">
                    <h6 class="text-secondary mb-3 text-uppercase small fw-bold">Thông tin cá nhân</h6>
                     <dl class="row">
                        <dt class="col-sm-4 text-muted">Họ và tên</dt>
                        <dd class="col-sm-8 fw-bold">@Model.HoTen</dd>

                        <dt class="col-sm-4 text-muted">Email</dt>
                        <dd class="col-sm-8">@(Model.Email ?? "Chưa cập nhật")</dd>

                        <dt class="col-sm-4 text-muted">Số điện thoại</dt>
                        <dd class="col-sm-8">@(Model.SoDienThoai ?? "Chưa cập nhật")</dd>
                        
                        <dt class="col-sm-4 text-muted">Ngày tạo</dt>
                        <dd class="col-sm-8">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>
                        
                         <dt class="col-sm-4 text-muted">Cập nhật cuối</dt>
                        <dd class="col-sm-8">@(Model.NgayCapNhat?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")</dd>
                    </dl>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                <a asp-action="Index" class="btn btn-light me-2">Quay lại danh sách</a>
                <a asp-action="Edit" asp-route-id="@Model.MaNguoiDung" class="btn btn-warning px-4"><i class="fas fa-pen me-1"></i> Chỉnh sửa</a>
            </div>
        </div>
    </div>
</div>

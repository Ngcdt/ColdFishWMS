@model ColdFishWMS.Models.Entities.NguoiDung
@{
    ViewData["Title"] = "Xóa người dùng";
}

<div class="container-fluid">
     <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Quản lý Người dùng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Xóa</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="fw-bold mb-0"><i class="fas fa-exclamation-triangle me-2"></i> Xác nhận xóa người dùng</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="fas fa-user-times fa-4x text-danger opacity-25 mb-3"></i>
                        <h4>Bạn có chắc chắn muốn xóa người dùng này?</h4>
                        <p class="text-muted">Hành động này không thể hoàn tác. Người dùng <strong>@Model.HoTen</strong> (@Model.TenDangNhap) sẽ bị xóa khỏi hệ thống.</p>
                    </div>

                    <dl class="row text-start bg-light p-3 rounded">
                        <dt class="col-sm-4">Họ và tên:</dt>
                        <dd class="col-sm-8">@Model.HoTen</dd>
                        
                        <dt class="col-sm-4">Tên đăng nhập:</dt>
                        <dd class="col-sm-8">@Model.TenDangNhap</dd>

                        <dt class="col-sm-4">Vai trò:</dt>
                        <dd class="col-sm-8">@Model.VaiTro?.TenVaiTro</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="MaNguoiDung" />
                        <div class="d-flex justify-content-center gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-danger px-4"><i class="fas fa-trash-alt me-2"></i> Xóa vĩnh viễn</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

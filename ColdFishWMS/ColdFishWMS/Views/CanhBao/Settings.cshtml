@model ColdFishWMS.Models.ViewModels.AlertConfigViewModel
@{
    ViewData["Title"] = "Cấu hình cảnh báo";
}

<div class="container-fluid p-0">
    <form asp-action="SaveSettings" method="post">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                 <h2 class="fw-bold text-dark mb-0">Cấu hình ngưỡng cảnh báo</h2>
                 <p class="text-muted small mb-0">Thiết lập các tham số cho hệ thống giám sát rủi ro</p>
            </div>
            <div>
                 <a asp-action="Index" class="btn btn-outline-secondary me-2">
                    <i class="fas fa-arrow-left me-2"></i> Trở về
                </a>
                <button type="submit" class="btn btn-primary shadow-sm">
                    <i class="fas fa-save me-2"></i> Lưu cấu hình
                </button>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                <div class="row g-4">
                    <!-- Ngưỡng tồn kho tối thiểu -->
                    <div class="col-md-6">
                        <label asp-for="MinStockThreshold" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="MinStockThreshold" class="form-control" type="number" min="0" />
                            <span class="input-group-text text-muted bg-light">đơn vị</span>
                        </div>
                        <div class="form-text text-muted small mt-1">
                            Cảnh báo khi tồn kho thấp hơn ngưỡng này (nếu sản phẩm chưa có định mức riêng).
                        </div>
                        <span asp-validation-for="MinStockThreshold" class="text-danger small"></span>
                    </div>

                    <!-- Số ngày cảnh báo HSD -->
                    <div class="col-md-6">
                        <label asp-for="ExpiryWarningDays" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="ExpiryWarningDays" class="form-control" type="number" min="0" />
                            <span class="input-group-text text-muted bg-light">ngày</span>
                        </div>
                        <div class="form-text text-muted small mt-1">
                            Cảnh báo trước khi sản phẩm hết hạn.
                        </div>
                        <span asp-validation-for="ExpiryWarningDays" class="text-danger small"></span>
                    </div>

                    <!-- Ngưỡng hiệu suất xuất kho -->
                     <div class="col-md-6">
                        <label asp-for="ExportEfficiencyThreshold" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="ExportEfficiencyThreshold" class="form-control" type="number" min="0" max="100" />
                            <span class="input-group-text text-muted bg-light">%</span>
                        </div>
                         <div class="form-text text-muted small mt-1">
                            Cảnh báo khi hiệu suất xuất kho thấp hơn.
                        </div>
                        <span asp-validation-for="ExportEfficiencyThreshold" class="text-danger small"></span>
                    </div>

                    <!-- Chu kỳ luân chuyển -->
                     <div class="col-md-6">
                        <label asp-for="BatchTurnoverCycle" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="BatchTurnoverCycle" class="form-control" type="number" min="0" />
                            <span class="input-group-text text-muted bg-light">ngày</span>
                        </div>
                         <div class="form-text text-muted small mt-1">
                            Thời gian tối đa cho một lô hàng trong kho.
                        </div>
                        <span asp-validation-for="BatchTurnoverCycle" class="text-danger small"></span>
                    </div>

                     <!-- Số ngày rủi ro hết hạn -->
                    <div class="col-md-6">
                        <label asp-for="ExpiryDangerDays" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="ExpiryDangerDays" class="form-control" type="number" min="0" />
                            <span class="input-group-text text-muted bg-light">ngày</span>
                        </div>
                        <div class="form-text text-muted small mt-1">
                            Cảnh báo rủi ro cao khi gần hết hạn.
                        </div>
                        <span asp-validation-for="ExpiryDangerDays" class="text-danger small"></span>
                    </div>

                    <!-- Nhiệt độ kho tối đa -->
                     <div class="col-md-6">
                        <label asp-for="MaxTemperature" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="MaxTemperature" class="form-control" type="number" step="0.1" />
                            <span class="input-group-text text-muted bg-light">°C</span>
                        </div>
                         <div class="form-text text-muted small mt-1">
                            Cảnh báo khi nhiệt độ vượt quá mức này.
                        </div>
                        <span asp-validation-for="MaxTemperature" class="text-danger small"></span>
                    </div>

                    <!-- Nhiệt độ kho tối thiểu -->
                     <div class="col-md-6">
                        <label asp-for="MinTemperature" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="MinTemperature" class="form-control" type="number" step="0.1" />
                            <span class="input-group-text text-muted bg-light">°C</span>
                        </div>
                         <div class="form-text text-muted small mt-1">
                            Cảnh báo khi nhiệt độ thấp hơn mức này.
                        </div>
                        <span asp-validation-for="MinTemperature" class="text-danger small"></span>
                    </div>

                    <!-- Tỷ lệ cảnh báo chiếm dụng kho -->
                     <div class="col-md-6">
                        <label asp-for="WarehouseOccupancyThreshold" class="form-label fw-bold text-secondary text-uppercase small"></label>
                        <div class="input-group">
                            <input asp-for="WarehouseOccupancyThreshold" class="form-control" type="number" min="0" max="100" />
                            <span class="input-group-text text-muted bg-light">%</span>
                        </div>
                         <div class="form-text text-muted small mt-1">
                            Cảnh báo khi tỷ lệ sử dụng kho vượt ngưỡng.
                        </div>
                        <span asp-validation-for="WarehouseOccupancyThreshold" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

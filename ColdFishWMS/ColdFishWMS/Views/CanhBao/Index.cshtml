@model IEnumerable<ColdFishWMS.Models.Entities.CanhBao>
@using ColdFishWMS.Models

@{
    ViewData["Title"] = "Cảnh báo & Rủi ro";
    bool isHistory = ViewBag.IsHistory == true;
    int highRiskCount = Model?.Count(x => x.MucDo == "Nguy hiểm") ?? 0;
    int totalCount = Model?.Count() ?? 0;
}

<div class="container-fluid">
    <!-- Header -->
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
             <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Cảnh báo & Rủi ro</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Cảnh báo & Rủi ro</h2>
            <p class="text-muted small mb-0">Giám sát các vấn đề kho hàng cần xử lý</p>
        </div>
        <div>
        @if (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho))
        {
            <a asp-action="Settings" class="btn btn-outline-secondary btn-sm me-2">
                <i class="fas fa-cog me-2"></i> Cấu hình
            </a>
        }
            <button class="btn btn-outline-primary btn-sm" onclick="location.href='@Url.Action("Index", new { refresh = true })'">
                <i class="fas fa-sync-alt me-2"></i> Làm mới
            </button>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1100">
        <div id="liveToast" class="toast align-items-center text-white bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
             <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="fas fa-check-circle me-2"></i> Đã làm mới danh sách
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
    
    @if (TempData["RefreshSuccess"] != null || TempData["Success"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                var toastEl = document.getElementById('liveToast');
                @if (TempData["Success"] != null)
                {
                    <text>
                    var body = toastEl.querySelector('.toast-body');
                    if(body) body.innerHTML = '<i class="fas fa-check-circle me-2"></i> @Html.Raw(TempData["Success"])';
                    </text>
                }
                var toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                toast.show();
            });
        </script>
    }

    <!-- Stats Cards -->
    @if (!isHistory) {
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-4 border-danger h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase fw-bold mb-1">Nguy hiểm</div>
                            <div class="h3 fw-bold text-danger mb-0">@highRiskCount</div>
                        </div>
                        <div class="text-danger opacity-25"><i class="fas fa-exclamation-circle fa-2x"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-4 border-warning h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase fw-bold mb-1">Cảnh báo</div>
                            <div class="h3 fw-bold text-warning mb-0">@(totalCount - highRiskCount)</div>
                        </div>
                        <div class="text-warning opacity-25"><i class="fas fa-exclamation-triangle fa-2x"></i></div>
                    </div>
                </div>
            </div>
        </div>
         <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-4 border-info h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase fw-bold mb-1">Sự vụ cần xử lý</div>
                            <div class="h3 fw-bold text-info mb-0">@totalCount</div>
                        </div>
                        <div class="text-info opacity-25"><i class="fas fa-bell fa-2x"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }

    <!-- Main Content -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pt-3 px-4">
            <ul class="nav nav-tabs card-header-tabs">
                <li class="nav-item">
                    <a class="nav-link @(!isHistory ? "active fw-bold bg-white text-primary" : "text-muted bg-light")" 
                       style="@(!isHistory ? "border-top: 3px solid #4e73df;" : "")"
                       href="@Url.Action("Index")">
                        <i class="fas fa-bolt me-2 @(!isHistory ? "text-warning" : "text-secondary")"></i>Cảnh báo hiện tại
                    </a>
                </li>
                <li class="nav-item ms-1">
                    <a class="nav-link @(isHistory ? "active fw-bold bg-white text-primary" : "text-muted bg-light")" 
                       style="@(isHistory ? "border-top: 3px solid #4e73df;" : "")"
                       href="@Url.Action("History")">
                        <i class="fas fa-history me-2 @(isHistory ? "text-primary" : "text-secondary")"></i>Lịch sử xử lý
                    </a>
                </li>
            </ul>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div>
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4" style="width: 50px;">
                                    <input type="checkbox" class="form-check-input">
                                </th>
                                <th>Nội dung cảnh báo</th>
                                <th>Loại</th>
                                <th>Mức độ</th>
                                <th>Thời gian</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <input type="checkbox" class="form-check-input">
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">@item.NoiDung</div>
                                    </td>
                                    <td>
                                        <span>@item.LoaiCanhBao</span>
                                    </td>
                                    <td>
                                        @if(item.MucDo == "Nguy hiểm") {
                                            <span class="badge bg-danger rounded-pill">Nghiêm trọng</span>
                                        } else {
                                            <span class="badge bg-warning text-dark rounded-pill">Cao</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                         @if(item.DaXuLy) {
                                            <span class="badge border border-success text-success bg-white px-3 py-2 rounded-pill fw-normal">Đã xử lý</span>
                                         } else {
                                            <span class="badge border border-primary text-primary bg-white px-3 py-2 rounded-pill fw-normal">Chưa xử lý</span>
                                         }
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho) || User.IsInRole(ColdFishWMS.Models.AppRoles.NhanVienKho))
                                        {
                                        <div class="dropdown">
                                            <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                                                <i class="fas fa-ellipsis-v"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                                @if(!item.DaXuLy && (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho) || User.IsInRole(ColdFishWMS.Models.AppRoles.NhanVienKho))) {
                                                <li>
                                                    <form asp-action="XuLy" method="post">
                                                        <input type="hidden" name="id" value="@item.MaCanhBao" />
                                                        <button type="submit" class="dropdown-item small"><i class="fas fa-check text-success me-2"></i>Xử lý</button>
                                                    </form>
                                                </li>
                                                }
                                                @if(User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho)) {
                                                <li>
                                                     <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                                                        <input type="hidden" name="id" value="@item.MaCanhBao" />
                                                        <button type="submit" class="dropdown-item small text-danger"><i class="fas fa-trash me-2"></i>Xóa</button>
                                                    </form>
                                                </li>
                                                }
                                            </ul>
                                        </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <img src="https://cdn-icons-png.flaticon.com/512/1182/1182749.png" width="64" class="mb-3 opacity-50" />
                    <h5>Hiện tại không có dữ liệu.</h5>
                </div>
            }
        </div>
    </div>
</div>

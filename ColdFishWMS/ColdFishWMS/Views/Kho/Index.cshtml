@model IEnumerable<ColdFishWMS.Models.Entities.LoHang>
@{
    ViewData["Title"] = "Quản lý kho hàng";
}

<div class="container-fluid">
    <!-- Header & Actions -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Quản lý kho hàng</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Quản lý kho hàng</h2>
            <p class="text-muted small mb-0">Quản lý nhập xuất kho, kiểm kê và điều chỉnh hàng hóa</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex flex-wrap gap-2">
            <a asp-controller="PhieuNhap" asp-action="Index" class="btn btn-primary shadow-sm">
                <i class="fas fa-box-open me-2"></i> Nhập kho
            </a>
            <a asp-controller="PhieuXuat" asp-action="Index" class="btn btn-success shadow-sm">
                <i class="fas fa-shipping-fast me-2"></i> Xuất kho
            </a>
             <a asp-controller="TonKho" asp-action="Index" class="btn btn-primary" style="background-color: #6f42c1; border-color: #6f42c1;">
                <i class="fas fa-clipboard-check me-2"></i> Kiểm kê
            </a>

            @if (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho) || User.IsInRole(ColdFishWMS.Models.AppRoles.KeToanKho))
            {
                <a asp-controller="BaoCao" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-file-alt me-2"></i> Báo cáo
                </a>
            }

        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-primary bg-opacity-10 text-primary me-2 p-2"><i class="fas fa-cubes fa-lg"></i></span>
                         <span class="text-muted small text-uppercase fw-bold">Tổng tồn kho</span>
                    </div>
                    <div class="h3 fw-bold text-primary mb-0">@ViewBag.TotalItems.ToString("N0")</div>
                    <div class="small text-muted">đơn vị sản phẩm</div>
                </div>
            </div>
        </div>
        @if (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho) || User.IsInRole(ColdFishWMS.Models.AppRoles.KeToanKho))
        {
            <div class="col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center mb-2">
                            <span class="badge bg-success bg-opacity-10 text-success me-2 p-2"><i class="fas fa-dollar-sign fa-lg"></i></span>
                            <span class="text-muted small text-uppercase fw-bold">Tổng giá trị</span>
                        </div>
                        <div class="h3 fw-bold text-success mb-0">@ViewBag.TotalValue.ToString("N0")</div>
                        <div class="small text-muted">VNĐ</div>
                    </div>
                </div>
            </div>
        }
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-danger bg-opacity-10 text-danger me-2 p-2"><i class="fas fa-exclamation-triangle fa-lg"></i></span>
                         <span class="text-muted small text-uppercase fw-bold">Lô cảnh báo HSD</span>
                    </div>
                    <div class="h3 fw-bold text-danger mb-0">@ViewBag.ExpiringSoon.ToString("N0")</div>
                    <div class="small text-muted">lô sắp hết hạn</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                         <span class="badge bg-info bg-opacity-10 text-info me-2 p-2"><i class="fas fa-layer-group fa-lg"></i></span>
                         <span class="text-muted small text-uppercase fw-bold">Tổng số lô</span>
                    </div>
                    <div class="h3 fw-bold text-info mb-0">@ViewBag.TotalBatches.ToString("N0")</div>
                    <div class="small text-muted">lô hàng trong kho</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Tabs -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pb-0 pt-3">
            <ul class="nav nav-tabs border-bottom-0" id="warehouseTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold border-bottom-0 border-top-0 border-start-0 border-end-0 text-primary" id="batches-tab" data-bs-toggle="tab" data-bs-target="#batches" type="button" role="tab" aria-controls="batches" aria-selected="true" style="border-bottom: 2px solid #4e73df !important;">
                        Quản lý lô hàng
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-muted" id="inventory-tab" type="button" role="tab" onclick="location.href='@Url.Action("Index", "TonKho")'">
                        Tồn kho tổng hợp
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body bg-white">
            <!-- Filter Bar (Visual) -->
            <!-- Filter Bar (Functional) -->
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0 bg-light" placeholder="Tìm sản phẩm / mã lô..." value="@ViewBag.CurrentSearch">
                    </div>
                </div>
                <div class="col-md-2">
                    <select name="location" class="form-select bg-light">
                        <option value="">Tất cả vị trí</option>
                        @if (ViewBag.Locations != null)
                        {
                            foreach (var loc in ViewBag.Locations)
                            {
                                if (ViewBag.CurrentLocation == loc.MaViTri)
                                {
                                    <option value="@loc.MaViTri" selected="@(loc.MaViTri == ViewBag.CurrentLocation)">
                                        @loc.MaViTri - @loc.TenViTri
                                    </option>
                                }
                                else
                                {
                                    <option value="@loc.MaViTri">@loc.MaViTri</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select bg-light">
                        <option value="">Tất cả trạng thái</option>
                        <!option value="valid" @(ViewBag.CurrentStatus == "valid" ? "selected" : "")>Còn hạn</!option>
                        <!option value="expiring" @(ViewBag.CurrentStatus == "expiring" ? "selected" : "")>Sắp hết hạn</!option>
                        <!option value="expired" @(ViewBag.CurrentStatus == "expired" ? "selected" : "")>Hết hạn</!option>
                    </select>
                </div>
                 <div class="col-md-auto ms-auto">
                     <button type="submit" class="btn btn-primary px-3">Áp dụng</button>
                     <a href="@Url.Action("Index", "Kho")" class="btn btn-outline-secondary px-3">Đặt lại</a>
                 </div>
            </form>

            <!-- Batches Table -->
            <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade show active" id="batches" role="tabpanel" aria-labelledby="batches-tab">
                     <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã lô</th>
                                    <th>Sản phẩm</th>
                                    <th>Vị trí</th>
                                    <th>Số lượng</th>
                                    <th>Hạn sử dụng</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var daysLeft = (item.HanSuDung - DateTime.Today).TotalDays;
                                    <tr>
                                        <td class="ps-4 fw-bold">@item.MaLoHang</td>
                                        <td>
                                            <div>@item.SanPham?.TenSanPham</div>
                                            <div class="small text-muted">@item.SanPham?.MaSanPham</div>
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@item.ViTriKho?.MaViTri</span></td>
                                        <td class="fw-bold">@item.SoLuongTon.ToString("N0")</td>
                                        <td>
                                            <div>@item.HanSuDung.ToString("dd/MM/yyyy")</div>
                                            @if (daysLeft < 30)
                                            {
                                                <small class="text-danger fw-bold">Còn @daysLeft.ToString("0") ngày</small>
                                            }
                                        </td>
                                        <td>
                                            @if (item.SoLuongTon <= 0) { <span class="badge bg-secondary">Hết hàng</span> }
                                            else if (daysLeft < 0) { <span class="badge bg-danger">Hết hạn</span> }
                                            else if (daysLeft < 30) { <span class="badge bg-warning text-dark">Sắp hết hạn</span> }
                                            else { <span class="badge bg-success">Đang lưu kho</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Nhập kho</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-0">
                <p class="text-muted small mb-3">Nhập thông tin lô hàng mới vào kho</p>
                <form asp-action="QuickImport" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Sản phẩm</label>
                         <!-- Suggesting Product Code -->
                        <div class="input-group">
                            <input type="text" name="SpCode" class="form-control" placeholder="Mã sp (VD: SP-CAHOI)" required>
                            <span class="input-group-text"><i class="fas fa-barcode"></i></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Mã lô</label>
                        <input type="text" name="MaLo" class="form-control" placeholder="Tự động hoặc nhập mã lô" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Số lượng</label>
                        <input type="number" name="SoLuong" class="form-control" placeholder="0" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Hạn sử dụng</label>
                        <input type="date" name="HanSuDung" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Vị trí kho</label>
                        <input type="text" name="ViTriCode" class="form-control" placeholder="Mã vị trí (VD: K1-01-01)" required>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary px-4">Xác nhận nhập</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Xuất kho</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-0">
                <p class="text-muted small mb-3">Xuất hàng nhanh theo nguyên tắc FEFO</p>
                <form asp-action="QuickExport" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Sản phẩm</label>
                        <input type="text" name="SpCode" class="form-control" placeholder="Nhập ID sản phẩm" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Số lượng xuất</label>
                        <input type="number" name="SoLuong" class="form-control" placeholder="0" required>
                    </div>
                    <div class="alert alert-info small mt-3">
                        <i class="fas fa-info-circle me-1"></i> Hệ thống sẽ tự động chọn lô hết hạn sớm nhất.
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success px-4">Xác nhận xuất</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

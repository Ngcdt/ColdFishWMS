@model ColdFishWMS.Models.ViewModels.PreviewReportViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
        @Model.Title 
        @if(Model.StartDate.HasValue && Model.EndDate.HasValue)
        {
             <span class="text-primary small fw-bold ms-2">(@Model.StartDate.Value.ToString("dd/MM/yyyy") - @Model.EndDate.Value.ToString("dd/MM/yyyy"))</span>
        }
        <span class="text-muted small fw-normal ms-2">(Cập nhật: @DateTime.Now.ToString("HH:mm"))</span>
    </h5>
    <div class="d-flex gap-2">
        @if (Model.Type == "Import")
        {
            <a href="@Url.Action("ExportImport", "BaoCao", new { startDate = Model.StartDate, endDate = Model.EndDate })" class="btn btn-success btn-sm">
                <i class="fas fa-file-excel me-2"></i> Tải xuống Excel
            </a>
        }
        else if (Model.Type == "Export")
        {
            <a href="@Url.Action("ExportExport", "BaoCao", new { startDate = Model.StartDate, endDate = Model.EndDate })" class="btn btn-danger btn-sm">
                <i class="fas fa-file-excel me-2"></i> Tải xuống Excel
            </a>
        }
        else
        {
            <a href="@Url.Action("ExportInventory", "BaoCao")" class="btn btn-warning btn-sm">
                <i class="fas fa-file-excel me-2"></i> Tải xuống Excel
            </a>
        }
    </div>
</div>



@if (Model.ChartLabels != null && Model.ChartLabels.Any())
{
    <div class="card mb-3 border-0 bg-light">
        <div class="card-body">
            <h6 class="fw-bold text-center mb-3">@Model.ChartTitle</h6>
            <div style="height: 200px;">
                <canvas id="previewChart"></canvas>
            </div>
        </div>
    </div>



    <!-- Data payload for Main Page JS to read -->
    <script id="preview-chart-data" type="application/json">
        {
            "labels": @Html.Raw(Json.Serialize(Model.ChartLabels)),
            "data": @Html.Raw(Json.Serialize(Model.ChartData)),
            "type": "@Model.Type",
            "title": "@Model.ChartTitle"
        }
    </script>
}

<div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
    <table class="table table-bordered table-sm table-hover" style="font-size: 0.9em;">
        <thead class="table-light sticky-top">
            @if (Model.Type == "Import")
            {
                <tr>
                    <th>Mã Phiếu</th>
                    <th>Ngày Nhập</th>
                    <th>Nhà Cung Cấp</th>
                    <th>Mã SP</th>
                    <th>Tên Sản Phẩm</th>
                    <th>Lô Hàng</th>
                    <th>Số Lượng</th>
                    <th>Đơn Giá</th>
                    <th>Thành Tiền</th>
                </tr>
            }
            else if (Model.Type == "Export")
            {
                <tr>
                    <th>Mã Phiếu</th>
                    <th>Ngày Xuất</th>
                    <th>Khách Hàng</th>
                    <th>Mã SP</th>
                    <th>Tên Sản Phẩm</th>
                    <th>Lô Hàng</th>
                    <th>Số Lượng</th>
                    <th>Đơn Giá</th>
                    <th>Thành Tiền</th>
                </tr>
            }
            else
            {
                <tr>
                    <th>Mã Lô</th>
                    <th>Mã SP</th>
                    <th>Tên Sản Phẩm</th>
                    <th>Vị Trí</th>
                    <th>NSX</th>
                    <th>HSD</th>
                    <th>Tồn Kho</th>
                    <th>Trạng Thái</th>
                </tr>
            }
        </thead>
        <tbody>
            @if (Model.Type == "Import")
            {
                foreach (var item in Model.DataImport)
                {
                    <tr>
                        <td>@item.MaPhieu</td>
                        <td>@item.NgayNhap.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.NhaCungCap</td>
                        <td>@item.MaSanPham</td>
                        <td>@item.TenSanPham</td>
                        <td>@item.MaLoHang</td>
                        <td class="text-end">@item.SoLuong.ToString("N0")</td>
                        <td class="text-end">@item.DonGia.ToString("N0")</td>
                        <td class="text-end fw-bold">@item.ThanhTien.ToString("N0")</td>
                    </tr>
                }
            }
            else if (Model.Type == "Export")
            {
                foreach (var item in Model.DataExport)
                {
                    <tr>
                        <td>@item.MaPhieu</td>
                        <td>@item.NgayXuat.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.KhachHang</td>
                        <td>@item.MaSanPham</td>
                        <td>@item.TenSanPham</td>
                        <td>@item.MaLoHang</td>
                        <td class="text-end">@item.SoLuong.ToString("N0")</td>
                        <td class="text-end">@item.DonGia.ToString("N0")</td>
                        <td class="text-end fw-bold">@item.ThanhTien.ToString("N0")</td>
                    </tr>
                }
            }
            else
            {
                foreach (var item in Model.DataInventory)
                {
                    <tr>
                        <td>@item.MaLo</td>
                        <td>@item.MaSanPham</td>
                        <td>@item.TenSanPham</td>
                        <td>@item.ViTri</td>
                        <td>@item.NgaySanXuat.ToString("dd/MM/yyyy")</td>
                        <td>@item.HanSuDung.ToString("dd/MM/yyyy")</td>
                        <td class="text-end fw-bold">@item.SoLuongTon.ToString("N0")</td>
                        <td>@item.TrangThai</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

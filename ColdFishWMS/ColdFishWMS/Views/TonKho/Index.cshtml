@model IEnumerable<ColdFishWMS.Models.Entities.LoHang>
@{
    ViewData["Title"] = "Kiểm kê Tồn kho";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <!-- Header & Actions -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Quản lý kho hàng</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Tồn kho tổng hợp</h2>
            <p class="text-muted small mb-0">Theo dõi tổng số lượng tồn kho của từng sản phẩm</p>
        </div>
         <div class="mt-3 mt-md-0 d-flex flex-wrap gap-2">
             <a asp-controller="Kho" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pb-0 pt-3">
            <ul class="nav nav-tabs border-bottom-0" id="warehouseTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-muted" id="batches-tab" type="button" role="tab" onclick="location.href='@Url.Action("Index", "Kho")'">
                        Quản lý lô hàng
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold border-bottom-0 border-top-0 border-start-0 border-end-0 text-primary" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory" type="button" role="tab" aria-controls="inventory" aria-selected="true" style="border-bottom: 2px solid #4e73df !important;">
                        Tồn kho tổng hợp
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body">
            <!-- Search Filter -->
             <form method="get" class="row g-2 mb-3">
                 <div class="col-md-4">
                     <div class="input-group">
                         <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                         <input type="text" name="search" class="form-control border-start-0 bg-light" placeholder="Tìm sản phẩm / mã lô..." value="@ViewBag.CurrentSearch">
                     </div>
                 </div>
                 <div class="col-md-auto">
                     <button type="submit" class="btn btn-primary px-3">Tìm kiếm</button>
                     <a href="@Url.Action("Index", "TonKho")" class="btn btn-outline-secondary px-3">Đặt lại</a>
                 </div>
             </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã lô</th>
                            <th>Sản phẩm</th>
                            <th>Số lượng tồn</th>
                            <th>Hạn sử dụng</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var nearlyExpired = (item.HanSuDung - DateTime.Today).TotalDays < 30;
                            <tr>
                                <td><span class="badge bg-light text-dark border">@item.MaLoHang</span></td>
                                <td>@item.SanPham?.TenSanPham</td>
                                <td class="fw-bold text-primary">@item.SoLuongTon.ToString("N0")</td>
                                <td>
                                    @item.HanSuDung.ToString("dd/MM/yyyy")
                                    @if(nearlyExpired && item.SoLuongTon > 0) { <i class="fas fa-exclamation-triangle text-warning ms-1" title="Sắp hết hạn"></i> }
                                </td>
                                <td>
                                    @if (item.SoLuongTon > 0)
                                    {
                                        <span class="badge bg-success">Còn hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết hàng</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


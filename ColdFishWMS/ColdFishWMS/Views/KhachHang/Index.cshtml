@model IEnumerable<ColdFishWMS.Models.Entities.KhachHang>
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
             <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Quản lý khách hàng</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Quản lý khách hàng</h2>
             <p class="text-muted small mb-0">Quản lý danh sách khách hàng và đối tác</p>
        </div>
        <div class="d-flex gap-2">
            @if(User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho)) {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="fas fa-plus me-2"></i> Thêm mới
            </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã KH</th>
                            <th>Tên khách hàng</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">@item.MaKhachHang</td>
                                <td class="fw-bold">@item.TenKhachHang</td>
                                <td>@item.SoDienThoai</td>
                                <td>@item.Email</td>
                                <td>
                                    @if(item.TrangThaiHoatDong)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary">Ngưng hoạt động</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if(User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho)) {
                                    <a asp-action="Edit" asp-route-id="@item.MaKhachHang" class="btn btn-light btn-sm text-primary me-2">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaKhachHang" class="btn btn-light btn-sm text-danger" onclick="return confirm('Bạn có chắc muốn xóa khách hàng này?');">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-users-slash fa-3x mb-3 opacity-50"></i>
                    <p>Chưa có dữ liệu khách hàng</p>
                </div>
            }
        </div>
    </div>
</div>

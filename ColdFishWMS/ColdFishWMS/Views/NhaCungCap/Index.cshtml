@model IEnumerable<ColdFishWMS.Models.Entities.NhaCungCap>
@{
    ViewData["Title"] = "Quản lý Nhà cung cấp";
}

<div class="container-fluid">
    <!-- Header & Actions -->
    <!-- Header & Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Quản lý Nhà cung cấp</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Nhà Cung Cấp</h2>
            <p class="text-muted small mb-0">Quản lý danh sách đối tác cung ứng</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho))
            {
            <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#createModal">
                <i class="fas fa-plus me-2"></i> Thêm mới
            </button>
            }
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0" 
                               placeholder="Tìm kiếm theo tên, SĐT, Email..." value="@ViewBag.SearchString">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Alerts handled by Global Toast -->

    <!-- Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Mã NCC</th>
                            <th>Tên nhà cung cấp</th>
                            <th>Địa chỉ</th>
                            <th>Liên hệ</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">@item.MaNhaCungCap</td>
                                    <td>
                                        <div class="fw-bold text-primary">@item.TenNhaCungCap</div>
                                    </td>
                                    <td>@item.DiaChi</td>
                                    <td>
                                        <div class="small"><i class="fas fa-phone me-1 text-muted"></i> @item.SoDienThoai</div>
                                        @if(!string.IsNullOrEmpty(item.Email)) {
                                            <div class="small"><i class="fas fa-envelope me-1 text-muted"></i> @item.Email</div>
                                        }
                                    </td>
                                    <td>
                                        @if (item.TrangThaiHoatDong)
                                        {
                                            <span class="badge border border-success text-success bg-white px-3 py-2 rounded-pill fw-normal">
                                                <i class="fas fa-check-circle me-1"></i> Đang hợp tác
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge border border-secondary text-secondary bg-white px-3 py-2 rounded-pill fw-normal">
                                                <i class="fas fa-pause-circle me-1"></i> Ngừng hợp tác
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (User.IsInRole(ColdFishWMS.Models.AppRoles.QuanLyKho))
                                        {
                                        <button class="btn btn-sm btn-outline-primary me-1" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#editModal-@item.MaNhaCungCap"
                                                title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <form asp-action="Delete" asp-route-id="@item.MaNhaCungCap" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa (ẩn) nhà cung cấp này?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                        }
                                    </td>
                                </tr>

                                <!-- Edit Modal -->
                                <div class="modal fade" id="editModal-@item.MaNhaCungCap" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title fw-bold">Cập nhật Nhà cung cấp</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <form asp-action="Edit" method="post">
                                                <div class="modal-body">
                                                    <input type="hidden" name="id" value="@item.MaNhaCungCap" />
                                                    <input type="hidden" name="MaNhaCungCap" value="@item.MaNhaCungCap" />
                                                    
                                                    <div class="mb-3">
                                                        <label class="form-label">Mã NCC <span class="text-danger">*</span></label>
                                                        <input type="text" class="form-control" name="MaNhaCungCap" value="@item.MaNhaCungCap" required>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Tên nhà cung cấp <span class="text-danger">*</span></label>
                                                        <input type="text" class="form-control" name="TenNhaCungCap" value="@item.TenNhaCungCap" required>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Địa chỉ</label>
                                                        <input type="text" class="form-control" name="DiaChi" value="@item.DiaChi">
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Số điện thoại</label>
                                                            <input type="text" class="form-control" name="SoDienThoai" value="@item.SoDienThoai">
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label">Email</label>
                                                            <input type="email" class="form-control" name="Email" value="@item.Email">
                                                        </div>
                                                    </div>
                                                    <div class="form-check form-switch mt-3">
                                                        <input class="form-check-input" type="checkbox" name="TrangThaiHoatDong" value="true" @(item.TrangThaiHoatDong ? "checked" : "")>
                                                        <label class="form-check-label">Hoạt động</label>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Không tìm thấy dữ liệu.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Thêm mới Nhà cung cấp</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Mã NCC <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="MaNhaCungCap" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tên nhà cung cấp <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="TenNhaCungCap" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" name="DiaChi">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Số điện thoại</label>
                            <input type="text" class="form-control" name="SoDienThoai">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="Email">
                        </div>
                    </div>
                    <input type="hidden" name="TrangThaiHoatDong" value="true" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Thêm mới</button>
                </div>
            </form>
        </div>
    </div>
</div>

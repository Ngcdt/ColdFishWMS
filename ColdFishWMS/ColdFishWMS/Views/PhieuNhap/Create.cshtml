@model ColdFishWMS.Models.Entities.PhieuNhap
@{
    ViewData["Title"] = "Tạo phiếu nhập";
}

<div class="mb-3">
    <a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none text-muted">
        <i class="fas fa-arrow-left me-1"></i> Quay lại Bảng điều khiển
    </a>
</div>

<h2><i class="fas fa-file-import"></i> Tạo phiếu nhập mới</h2>
<hr />

<form asp-action="Create" method="post" id="formPhieuNhap">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin phiếu nhập</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NgayNhap" class="form-label">Ngày nhập *</label>
                            <input asp-for="NgayNhap" class="form-control" type="date" />
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="MaNhaCungCap" class="form-label">Nhà cung cấp *</label>
                            <select asp-for="MaNhaCungCap" class="form-select">
                                <option value="">-- Chọn nhà cung cấp --</option>
                                @foreach (var ncc in ViewBag.NhaCungCaps as List<ColdFishWMS.Models.Entities.NhaCungCap>)
                                {
                                    <option value="@ncc.MaNhaCungCap">@ncc.TenNhaCungCap</option>
                                }
                            </select>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="GhiChu" class="form-label">Ghi chú</label>
                        <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>
            
            <div class="card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Chi tiết phiếu nhập</h5>
                    <button type="button" class="btn btn-light btn-sm" onclick="themDongMoi()">
                        <i class="fas fa-plus"></i> Thêm dòng
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered" id="tableChiTiet">
                            <thead>
                                <tr>
                                    <th style="width: 40%">Sản phẩm</th>
                                    <th style="width: 25%">Số lượng</th>
                                    <th style="width: 25%">Đơn giá</th>
                                    <th style="width: 10%"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Các dòng chi tiết sẽ được thêm bằng JavaScript -->
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5" class="text-end"><strong>Tổng tiền:</strong></td>
                                    <td colspan="3"><strong id="tongTien">0 VNĐ</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            
            <div class="mt-3">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save"></i> Lưu phiếu nhập
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        let dongIndex = 0;
        const sanPhams = @Html.Raw(Json.Serialize(((List<ColdFishWMS.Models.Entities.SanPham>)ViewBag.SanPhams).Select(s => new { maSanPham = s.MaSanPham, tenSanPham = s.TenSanPham, giaNhap = s.GiaNhapMacDinh, donViTinh = new { tenDonViTinh = s.DonViTinh?.TenDonViTinh ?? "" } })));
        
        function themDongMoi() {
            const html = `
                <tr>
                    <td>
                        <select name="chiTietList[${dongIndex}].MaSanPham" class="form-select form-select-sm sanPhamSelect" required onchange="capNhatGia(this)">
                            <option value="">-- Chọn sản phẩm --</option>
                            ${sanPhams.map(sp => `<option value="${sp.maSanPham}" data-gia="${sp.giaNhap}">${sp.tenSanPham} (${sp.donViTinh.tenDonViTinh})</option>`).join('')}
                        </select>
                    </td>
                    <td>
                        <input type="number" name="chiTietList[${dongIndex}].SoLuong" class="form-control form-control-sm soLuong" step="0.01" required />
                    </td>
                    <td>
                        <input type="number" name="chiTietList[${dongIndex}].DonGia" class="form-control form-control-sm donGia" step="0.01" required />
                    </td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm" onclick="xoaDong(this)">
                            <i class="fas fa-times"></i>
                        </button>
                    </td>
                </tr>
            `;
            
            $('#tableChiTiet tbody').append(html);
            dongIndex++;
            
            $('.soLuong, .donGia').off('input').on('input', tinhTongTien);
        }
        
        function capNhatGia(selectElement) {
            const gia = $(selectElement).find(':selected').data('gia') || 0;
            $(selectElement).closest('tr').find('.donGia').val(gia);
            tinhTongTien();
        }
        
        function xoaDong(btn) {
            $(btn).closest('tr').remove();
            tinhTongTien();
        }
        
        function tinhTongTien() {
            let tong = 0;
            $('#tableChiTiet tbody tr').each(function() {
                const soLuong = parseFloat($(this).find('.soLuong').val()) || 0;
                const donGia = parseFloat($(this).find('.donGia').val()) || 0;
                tong += soLuong * donGia;
            });
            
            $('#tongTien').text(tong.toLocaleString('vi-VN') + ' VNĐ');
        }
        
        $(document).ready(function() {
            themDongMoi();
            
            // Handle Form Submit
            $('#formPhieuNhap').on('submit', function() {
                updateIndices();
                return true;
            });
        });

        function updateIndices() {
            $('#tableChiTiet tbody tr').each(function(index) {
                $(this).find('select, input').each(function() {
                    let name = $(this).attr('name');
                    if (name) {
                        const newName = name.replace(/\[\d+\]/, `[${index}]`);
                        $(this).attr('name', newName);
                    }
                });
            });
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}


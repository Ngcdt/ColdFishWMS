@model IEnumerable<ColdFishWMS.Models.Entities.PhieuNhap>
@{
    ViewData["Title"] = "Phiếu nhập";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Phiếu nhập</h2>
    <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Mã phiếu</th>
            <th>Ngày nhập</th>
            <th>Nhà cung cấp</th>
            <th>Tổng tiền</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.MaPhieuNhap</td>
            <td>@item.NgayNhap.ToString("dd/MM/yyyy")</td>
            <td>@(item.NhaCungCap?.TenNhaCungCap ?? "-")</td>
            <td>@item.TongTien.ToString("N0") VNĐ</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.MaPhieuNhap" class="btn btn-sm btn-outline-secondary">Xem</a>
                @if (!item.DaDuyet)
                {
                    <a asp-action="NhapKho" asp-route-id="@item.MaPhieuNhap" class="btn btn-sm btn-success ms-1">Nhập kho</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>






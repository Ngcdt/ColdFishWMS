@model ColdFishWMS.Models.Entities.PhieuNhap
@{
    ViewData["Title"] = "Nhập kho - " + Model.MaPhieuNhap;
    var viTriKhos = ViewBag.ViTriKhos as List<ColdFishWMS.Models.Entities.ViTriKho> ?? new List<ColdFishWMS.Models.Entities.ViTriKho>();
}

<div class="mb-3">
    <a asp-controller="PhieuNhap" asp-action="Index" class="text-decoration-none text-muted">
        <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<h2><i class="fas fa-boxes"></i> Nhập kho: @Model.MaPhieuNhap</h2>
<div class="alert alert-info">
    <i class="fas fa-info-circle"></i> Vui lòng kiểm tra hàng hóa, gán số lô và vị trí lưu kho cho từng sản phẩm.
</div>
<hr />

<form asp-action="NhapKho" method="post">
    <input type="hidden" asp-for="MaPhieuNhap" />
    
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0 text-primary">Thông tin phiếu nhập</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Nhà cung cấp:</strong> @Model.NhaCungCap?.TenNhaCungCap
                </div>
                <div class="col-md-4">
                    <strong>Ngày nhập:</strong> @Model.NgayNhap.ToString("dd/MM/yyyy")
                </div>
                <div class="col-md-4">
                    <strong>Người tạo:</strong> @Model.NguoiTao?.HoTen
                </div>
            </div>
            <div class="mt-2 text-muted fst-italic">
                Ghi chú: @(Model.GhiChu ?? "Không có")
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Chi tiết nhập kho</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 25%">Sản phẩm</th>
                            <th style="width: 10%">ĐVT</th>
                            <th style="width: 10%">Số lượng</th>
                            <th style="width: 20%">Số lô (Đề xuất)</th>
                            <th style="width: 15%">NSX</th>
                            <th style="width: 15%">HSD</th>
                            <th style="width: 15%">Vị trí kho</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.ChiTietPhieuNhaps.Count; i++)
                        {
                            var item = Model.ChiTietPhieuNhaps.ElementAt(i);
                            var spCode = item.SanPham?.MaSanPham ?? "SP";
                            var dateCode = DateTime.Now.ToString("yyMMdd");
                            var lotSuggestion = $"LOT-{spCode}-{dateCode}";
                            
                            <input type="hidden" name="chiTietList[@i].MaChiTiet" value="@item.MaChiTiet" />
                            <input type="hidden" name="chiTietList[@i].MaPhieuNhap" value="@item.MaPhieuNhap" />
                            <input type="hidden" name="chiTietList[@i].MaSanPham" value="@item.MaSanPham" />
                            <input type="hidden" name="chiTietList[@i].SoLuong" value="@item.SoLuong" />
                            <input type="hidden" name="chiTietList[@i].DonGia" value="@item.DonGia" />

                            <tr>
                                <td>
                                    <strong>@item.SanPham?.TenSanPham</strong><br/>
                                    <small class="text-muted">@item.MaSanPham</small>
                                </td>
                                <td>@item.SanPham?.DonViTinh?.TenDonViTinh</td>
                                <td class="text-center fw-bold">@item.SoLuong.ToString("N2")</td>
                                <td>
                                    <input type="text" name="chiTietList[@i].MaLoHang" class="form-control form-control-sm" value="@lotSuggestion" required />
                                </td>
                                <td>
                                    <input type="date" name="chiTietList[@i].LoHang.NgaySanXuat" class="form-control form-control-sm" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                </td>
                                <td>
                                    <input type="date" name="chiTietList[@i].LoHang.HanSuDung" class="form-control form-control-sm" value="@DateTime.Now.AddYears(1).ToString("yyyy-MM-dd")" required />
                                </td>
                                <td>
                                    <select name="chiTietList[@i].LoHang.MaViTri" class="form-select form-select-sm" required>
                                        <option value="">-- Chọn vị trí --</option>
                                        @foreach (var vt in viTriKhos)
                                        {
                                            <option value="@vt.MaViTri">@vt.MaViTri</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white d-flex justify-content-end p-3">
             <a asp-action="Index" class="btn btn-secondary me-2">Hủy bỏ</a>
             <button type="submit" class="btn btn-success btn-lg">
                 <i class="fas fa-check-circle me-1"></i> Xác nhận Nhập Kho
             </button>
        </div>
    </div>
</form>
